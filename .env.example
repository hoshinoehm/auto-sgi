# =============================================================
# AUTO SGI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no git.
# =============================================================

# --- Credenciais do SGI ---
SGI_USUARIO=2645349
SGI_SENHA=sua_senha_aqui

# --- Autenticação da API (header X-API-Key) ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=gere_uma_chave_aqui

# --- Diretório de dados persistentes ---
# No container Docker: /data (montado como volume)
# Local (Windows para testes): C:/Users/hoshi/auto_sgi_data
DATA_DIR=/data

# --- Selenium / Chrome ---
# true  = roda sem janela (produção/VPS)
# false = abre o navegador (debug local)
HEADLESS=true

# Caminhos do Chrome no container (Debian/Ubuntu com chromium)
CHROME_BIN=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# Timeout em segundos para operações Selenium
SELENIUM_TIMEOUT=30

# --- Servidor FastAPI ---
HOST=0.0.0.0
PORT=8000
